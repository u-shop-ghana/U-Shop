# Apps API Environment Variables
# Copy this to .env and fill in the values

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug

# ─── Database (Supabase PostgreSQL) ───────────
DATABASE_URL="postgresql://user:password@localhost:5432/ushop?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ushop?schema=public"

# ─── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Paystack ─────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ─── Upstash Redis ────────────────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# ─── Resend (Email) ──────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@ushop.com

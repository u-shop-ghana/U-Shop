# Version control
.git
.gitignore

# Build artefacts (rebuilt inside the image)
development/apps/api/dist
development/apps/web/.next
development/apps/web/out

# Dependency directories (will be installed fresh inside the image)
**/node_modules

# Environment files (secrets come from Railway/Vercel env vars at runtime)
**/.env
**/.env.*
!**/.env.example

# OS / editor noise
.DS_Store
**/.DS_Store
Thumbs.db

# Logs
**/*.log
**/npm-debug.log*
**/pnpm-debug.log*

# Test artefacts
**/coverage
**/.nyc_output

# Comment 6: Exclude non-runtime directories from Docker context
# These add significant bloat and are never needed at runtime.
docs/
design/
business/
deployment/
testing/
assets/

# Scratch / diagnostic scripts — never belong in production images
development/apps/api/scratch/
development/apps/api/check-unis.ts

# Figma, markdown, and HTML docs
*.md
*.html
*.fig
*.pdf

# IDE / editor config
.vscode/
.idea/
